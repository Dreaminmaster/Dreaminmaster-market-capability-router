{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlatformTerm",
  "type": "object",
  "required": [
    "term",
    "canonical_concept",
    "platform",
    "expression_type",
    "risk_level",
    "confidence",
    "last_verified",
    "status"
  ],
  "properties": {
    "term": {
      "type": "string",
      "minLength": 1
    },
    "canonical_concept": {
      "type": "string",
      "minLength": 1
    },
    "platform": {
      "type": "string"
    },
    "expression_type": {
      "type": "string"
    },
    "possible_services": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical",
        "unknown"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "first_seen": {
      "type": "string"
    },
    "last_verified": {
      "type": "string"
    },
    "evidence_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "enum": [
        "candidate",
        "verified",
        "deprecated"
      ]
    }
  }
}
